{
	"schemaVersion": 1,
	"id": "simpleskinswapper",
	"version": "${version}",
	"name": "Simple Skin Swapper",
	"description": "Swap your skin on the fly with a radial wheel or carousel. Supports per-server commands for real-time updates without reconnecting.",
	"authors": [
		"Raconteur"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/simpleskinswapper",
		"sources": "https://github.com/Raconteur32/SimpleSkinLoader",
		"issues": "https://github.com/Raconteur32/SimpleSkinLoader/issues"
	},
	"license": "LGPL-3.0-or-later",
	"icon": "assets/simpleskinswapper/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"fr.raconteur.simpleskinswapper.SimpleSkinSwapper"
		],
		"client": [
			"fr.raconteur.simpleskinswapper.SimpleSkinSwapperClient"
		],
		"modmenu": [
			"fr.raconteur.simpleskinswapper.config.ModMenuCompat"
		]
	},
	"mixins": [
		"simpleskinswapper.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.15",
		"minecraft": ">=1.21.8 <=1.21.11",
		"fabric-api": "*"
	},
	"suggests": {
		"modmenu": "*"
	}
}
